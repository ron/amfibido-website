<script>
(function() {
  var lightbox = document.getElementById('sellsheet-lightbox');
  var imgEl = document.getElementById('sellsheet-lightbox-img');
  var captionEl = document.getElementById('sellsheet-lightbox-caption');
  var btnClose = document.getElementById('sellsheet-lightbox-close');
  var btnPrev = document.getElementById('sellsheet-lightbox-prev');
  var btnNext = document.getElementById('sellsheet-lightbox-next');
  var thumbs = document.querySelectorAll('.sellsheet-thumb');
  if (!lightbox || !imgEl || !thumbs.length) return;

  var urls = [];
  var alts = [];
  var index = 0;

  thumbs.forEach(function(btn, i) {
    urls.push(btn.getAttribute('data-full') || '');
    alts.push(btn.getAttribute('data-alt') || '');
    btn.addEventListener('click', function() {
      index = i;
      open();
    });
  });

  function open() {
    imgEl.src = urls[index];
    imgEl.alt = alts[index];
    captionEl.textContent = alts[index];
    lightbox.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    btnClose.focus();
  }

  function close() {
    lightbox.classList.add('hidden');
    imgEl.removeAttribute('src');
    document.body.style.overflow = '';
  }

  function show(delta) {
    index = (index + delta + urls.length) % urls.length;
    imgEl.src = urls[index];
    imgEl.alt = alts[index];
    captionEl.textContent = alts[index];
  }

  btnClose.addEventListener('click', close);
  lightbox.addEventListener('click', function(e) {
    if (e.target === lightbox) close();
  });
  btnPrev.addEventListener('click', function(e) { e.stopPropagation(); show(-1); });
  btnNext.addEventListener('click', function(e) { e.stopPropagation(); show(1); });

  document.addEventListener('keydown', function(e) {
    if (lightbox.classList.contains('hidden')) return;
    if (e.key === 'Escape') close();
    if (e.key === 'ArrowLeft') show(-1);
    if (e.key === 'ArrowRight') show(1);
  });
})();
</script>
