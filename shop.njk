---
layout: base.njk
title: "Shop | Amfibido Card Game"
description: "Buy Amfibido, the strategic 2-player card game. Get the complete game, playmats, and accessories."
---

<section class="py-12 md:py-20 bg-[#fafaf8]">
  <div class="container mx-auto px-4 md:px-6">
    <div class="max-w-5xl mx-auto">
      <!-- Header -->
      <div class="text-center mb-12">
        <h1 class="text-4xl md:text-5xl font-headings font-bold text-[#2d5a27] mb-4">Shop</h1>
        <p class="text-lg text-gray-700 max-w-2xl mx-auto">
          Get your own copy of Amfibido and bring the dojo battles to your table.
        </p>
      </div>

      <!-- Loading State -->
      <div id="shop-loading" class="text-center py-16">
        <div class="inline-block w-8 h-8 border-4 border-[#2d5a27]/20 border-t-[#2d5a27] rounded-full animate-spin"></div>
        <p class="mt-4 text-gray-600">Loading shop...</p>
      </div>

      <!-- Coming Soon Banner (hidden by default) -->
      <div id="shop-unavailable" class="hidden mb-8">
        <div class="bg-amber-50 border border-amber-200 rounded-xl p-4 md:p-6 text-center">
          <p class="text-amber-800 font-medium mb-3">
            🌍 We're not shipping to <span id="user-country">your country</span> yet, but we're working on it! <br />Leave your email and we'll let you know when Amfibido becomes available in your area.
          </p>
          <form action="https://amfibido.us16.list-manage.com/subscribe/post?u=612f57a4d3111090b99807845&amp;id=63e4f2e7d4"
                method="post"
                id="mc-embedded-subscribe-form-shop"
                name="mc-embedded-subscribe-form"
                class="flex flex-col sm:flex-row justify-center items-center gap-3 max-w-md mx-auto"
                target="_blank">
            <input type="email" name="EMAIL" placeholder="Enter your email" required
                   class="w-full sm:w-auto flex-1 px-4 py-2 rounded-lg border border-amber-300 focus:outline-none focus:ring-2 focus:ring-[#2d5a27] focus:border-transparent text-sm">
            <input type="hidden" name="COUNTRY" id="mc-country" value="">
            <input type="hidden" name="SHOP" value="true">
            <button type="submit" name="subscribe"
                    class="btn btn-primary px-6 py-2 text-sm whitespace-nowrap">
              Notify Me
            </button>
          </form>
        </div>
      </div>

      <!-- Products Grid -->
      <div id="shop-products" class="hidden">
      <div class="grid md:grid-cols-3 gap-8 mb-16">
        <!-- Product 1: Amfibido Game -->
        <div class="bg-white rounded-2xl shadow-lg overflow-hidden flex flex-col transition-transform duration-300 hover:scale-[1.02] hover:shadow-xl">
          <div class="aspect-square bg-gray-100 p-4">
            <img src="{{ '/images/shop/amfibido-game.png' | url }}" alt="Amfibido Game" class="w-full h-full object-contain">
          </div>
          <div class="p-6 flex flex-col flex-grow">
            <h2 class="text-xl font-headings font-bold text-[#2d5a27] mb-2">Amfibido Game</h2>
            <p class="text-gray-600 mb-4 flex-grow">
              The complete Amfibido card game including Dojo cards. Everything you need to play in one box.
            </p>
            <div class="flex items-center justify-between mt-auto">
              <span class="text-2xl font-bold text-[#2d5a27]">€22,99</span>
              <a href="#" class="btn btn-primary px-6 py-2 buy-btn" data-product="game">
                View & Buy
              </a>
            </div>
          </div>
        </div>

        <!-- Product 2: Amfibido Game + 2 Playmats -->
        <div class="bg-white rounded-2xl shadow-lg overflow-hidden flex flex-col transition-transform duration-300 hover:scale-[1.02] hover:shadow-xl">
          <div class="aspect-square bg-gray-100 p-4">
            <img src="{{ '/images/shop/amfibido-game-playmats.png' | url }}" alt="Amfibido Game + 2 Playmats" class="w-full h-full object-contain">
          </div>
          <div class="p-6 flex flex-col flex-grow">
            <h2 class="text-xl font-headings font-bold text-[#2d5a27] mb-2">Amfibido Game + 2 Playmats</h2>
            <p class="text-gray-600 mb-4 flex-grow">
              The complete card game plus 2 premium soft rubber playmats (40×25 cm). Perfect playing surface for your dojo battles.
            </p>
            <div class="flex items-center justify-between mt-auto">
              <span class="text-2xl font-bold text-[#2d5a27]">€33,99</span>
              <a href="#" class="btn btn-primary px-6 py-2 buy-btn" data-product="game-playmats">
                View & Buy
              </a>
            </div>
          </div>
        </div>

        <!-- Product 3: Amfibido Game + 2 Playmats + Dice Bag -->
        <div class="bg-white rounded-2xl shadow-lg overflow-hidden flex flex-col transition-transform duration-300 hover:scale-[1.02] hover:shadow-xl relative">
          <!-- Best Value Badge -->
          <div class="absolute top-4 right-4 bg-[#ff6b1f] text-white text-xs font-bold px-3 py-1 rounded-full z-10">
            Best Value
          </div>
          <div class="aspect-square bg-gray-100 p-4">
            <img src="{{ '/images/shop/amfibido-game-playmats-dice.png' | url }}" alt="Amfibido Game + 2 Playmats + Dice Bag" class="w-full h-full object-contain">
          </div>
          <div class="p-6 flex flex-col flex-grow">
            <h2 class="text-xl font-headings font-bold text-[#2d5a27] mb-2">Amfibido Complete Bundle</h2>
            <p class="text-gray-600 mb-4 flex-grow">
              The ultimate package: complete card game, 2 soft rubber playmats (40×25 cm), plus a dice bag with 6× D6, 6× D12, and 6× D20 dice.
            </p>
            <div class="flex items-center justify-between mt-auto">
              <span class="text-2xl font-bold text-[#2d5a27]">€39,99</span>
              <a href="#" class="btn btn-accent px-6 py-2 buy-btn" data-product="bundle">
                View & Buy
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Bulk Order Section -->
      <div class="bg-[#2d5a27]/10 rounded-2xl p-8 text-center">
        <h3 class="text-xl font-headings font-bold text-[#2d5a27] mb-2">Interested in buying more than one?</h3>
        <p class="text-gray-700">
          Contact us by <a href="mailto:ron@amfibido.com" class="text-[#2d5a27] font-semibold hover:underline">email</a>
        </p>
      </div>

      <!-- Terms & Privacy Link -->
      <div class="mt-8 text-center">
        <a href="{{ '/terms' | url }}" class="inline-flex items-center text-gray-600 hover:text-[#2d5a27] transition-colors">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
          Terms, Conditions & Privacy Policy
        </a>
      </div>
      </div><!-- end #shop-products -->
    </div>
  </div>
</section>

<!-- Checkout Modal -->
<div id="checkout-modal" class="fixed inset-0 z-50 hidden">
  <!-- Backdrop -->
  <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" id="modal-backdrop"></div>
  
  <!-- Modal Content -->
  <div class="absolute inset-0 flex items-center justify-center p-4">
    <div class="bg-white rounded-2xl shadow-2xl max-w-2xl w-full max-h-[90vh] overflow-y-auto relative">
      <!-- Close Button -->
      <button id="modal-close" class="absolute top-4 right-4 p-2 text-gray-400 hover:text-gray-600 transition-colors z-10">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>

      <div class="p-6 md:p-8">
        <!-- Image Carousel -->
        <div class="relative bg-gray-100 rounded-xl p-6 mb-6">
          <!-- Carousel Container -->
          <div id="carousel-container" class="relative overflow-hidden">
            <div id="carousel-track" class="flex transition-transform duration-300 ease-out">
            </div>
          </div>
          
          <!-- Navigation Arrows -->
          <button id="carousel-prev" class="absolute left-2 top-1/2 -translate-y-1/2 w-10 h-10 bg-white/90 hover:bg-white rounded-full shadow-lg flex items-center justify-center text-gray-700 hover:text-[#2d5a27] transition-colors z-10">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
            </svg>
          </button>
          <button id="carousel-next" class="absolute right-2 top-1/2 -translate-y-1/2 w-10 h-10 bg-white/90 hover:bg-white rounded-full shadow-lg flex items-center justify-center text-gray-700 hover:text-[#2d5a27] transition-colors z-10">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </button>
          
          <!-- Dots Indicator -->
          <div id="carousel-dots" class="flex justify-center gap-2 mt-4">
          </div>
        </div>

        <!-- Product Name & Price (Mobile: stacked on top, Desktop: side of includes) -->
        <div class="md:hidden mb-4 text-center">
          <h2 id="modal-title-mobile" class="text-2xl font-headings font-bold text-[#2d5a27] mb-1"></h2>
          <p id="modal-price-mobile" class="text-3xl font-bold text-[#2d5a27]"></p>
        </div>

        <!-- Product Info Row (Desktop layout) -->
        <div class="flex flex-col md:flex-row gap-4 mb-6">
          <!-- What's Included (Left) -->
          <div class="flex-1">
            <h3 class="font-semibold text-gray-900 mb-3">What's included:</h3>
            <ul id="modal-includes" class="space-y-2 text-gray-700">
            </ul>
          </div>
          
          <!-- Name & Price (Right - Desktop only) -->
          <div class="hidden md:block text-right shrink-0">
            <h2 id="modal-title" class="text-2xl font-headings font-bold text-[#2d5a27] mb-2"></h2>
            <p id="modal-price" class="text-3xl font-bold text-[#2d5a27]"></p>
          </div>
        </div>

        <!-- Terms Checkbox -->
        <div class="mb-6">
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" id="terms-checkbox" class="mt-1 w-5 h-5 rounded border-gray-300 text-[#2d5a27] focus:ring-[#2d5a27] cursor-pointer">
            <span class="text-gray-700 text-sm">
              I agree to the <a href="{{ '/terms' | url }}" target="_blank" class="text-[#2d5a27] hover:underline font-medium">Terms, Conditions & Privacy Policy</a>
            </span>
          </label>
          <p id="terms-error" class="text-red-500 text-sm mt-2 hidden">Please accept the terms and conditions to continue.</p>
        </div>

        <!-- Checkout Button -->
        <button id="modal-checkout-btn" class="w-full btn btn-primary py-4 text-lg font-semibold flex items-center justify-center gap-2">
          <span>Proceed to Checkout</span>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </button>

        <!-- Secure Payment Note -->
        <p class="text-center text-gray-500 text-sm mt-4 flex items-center justify-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
          </svg>
          Secure payment via Stripe
        </p>

        <!-- Shipping Info -->
        <p class="text-xs text-gray-500 text-center mt-1">
          <span class="font-medium text-gray-600">Shipping within EU</span> · Shipping costs calculated at checkout. Estimated delivery: 3-7 business days.
        </p>
      </div>
    </div>
  </div>
</div>

<script>
(function() {
  const SUPPORTED_COUNTRIES = ['NL', 'DE', 'GB', 'BE'];

  const STRIPE_LINKS = {
    NL: {
      game: 'https://buy.stripe.com/5kQ8wQ5Yf2VWf8w3jW7bW04',
      'game-playmats': 'https://buy.stripe.com/8x2fZi3Q77cce4s07K7bW08',
      bundle: 'https://buy.stripe.com/3cI3cw2M3gMMaSg6w87bW0c'
    },
    DE: {
      game: 'https://buy.stripe.com/14A14ogCT4000dCcUw7bW03',
      'game-playmats': 'https://buy.stripe.com/00wbJ2dqHbss3pO3jW7bW07',
      bundle: 'https://buy.stripe.com/4gMbJ23Q70NO8K8f2E7bW0b'
    },
    GB: {
      game: 'https://buy.stripe.com/14AdRagCT5442lK1bO7bW01',
      'game-playmats': 'https://buy.stripe.com/aFa3cwdqHbss4tS1bO7bW05',
      bundle: 'https://buy.stripe.com/dRmbJ21HZ7ccd0o9Ik7bW09'
    },
    BE: {
      game: 'https://buy.stripe.com/3cIbJ2fyP400bWk9Ik7bW02',
      'game-playmats': 'https://buy.stripe.com/6oU28s2M3400gcA9Ik7bW06',
      bundle: 'https://buy.stripe.com/8x214o1HZ7cc4tS7Ac7bW0a'
    }
  };

  const PRODUCT_DATA = {
    game: {
      title: 'Amfibido Game',
      price: '€22,99',
      images: [
        '{{ "/images/shop/amfibido-game.png" | url }}',
        '{{ "/images/shop/game-content.png" | url }}'
      ],
      includes: [
        '157 playing cards',
        'Full rulebook',
        'Score board with 3 wooden tokens'
      ]
    },
    'game-playmats': {
      title: 'Amfibido Game + 2 Playmats',
      price: '€33,99',
      images: [
        '{{ "/images/shop/amfibido-game-playmats.png" | url }}',
        '{{ "/images/shop/game-content.png" | url }}',
        '{{ "/images/shop/playmats.png" | url }}'
      ],
      includes: [
        '157 playing cards',
        'Full rulebook',
        'Score board with 3 wooden tokens',
        'High quality Rubber Playmats (40×25 cm) 2×'
      ]
    },
    bundle: {
      title: 'Amfibido Complete Bundle',
      price: '€39,99',
      images: [
        '{{ "/images/shop/amfibido-game-playmats-dice.png" | url }}',
        '{{ "/images/shop/game-content.png" | url }}',
        '{{ "/images/shop/playmats.png" | url }}',
        '{{ "/images/shop/dice.png" | url }}'
      ],
      includes: [
        '157 playing cards',
        'Full rulebook',
        'Score board with 3 wooden tokens',
        'Playmats (40×25 cm) 2×',
        'Dice bag with 6× D6, 6× D12, 6× D20 dice'
      ]
    }
  };

  let currentStripeLink = null;
  let currentCountry = 'NL';
  let currentSlide = 0;
  let totalSlides = 0;

  // Modal elements
  const modal = document.getElementById('checkout-modal');
  const modalBackdrop = document.getElementById('modal-backdrop');
  const modalClose = document.getElementById('modal-close');
  const carouselTrack = document.getElementById('carousel-track');
  const carouselDots = document.getElementById('carousel-dots');
  const carouselPrev = document.getElementById('carousel-prev');
  const carouselNext = document.getElementById('carousel-next');
  const modalTitle = document.getElementById('modal-title');
  const modalPrice = document.getElementById('modal-price');
  const modalIncludes = document.getElementById('modal-includes');
  const termsCheckbox = document.getElementById('terms-checkbox');
  const termsError = document.getElementById('terms-error');
  const checkoutBtn = document.getElementById('modal-checkout-btn');

  function updateCarousel() {
    carouselTrack.style.transform = `translateX(-${currentSlide * 100}%)`;
    
    // Update dots
    const dots = carouselDots.querySelectorAll('button');
    dots.forEach((dot, i) => {
      dot.classList.toggle('bg-[#2d5a27]', i === currentSlide);
      dot.classList.toggle('bg-gray-300', i !== currentSlide);
    });

    // Update arrow visibility
    carouselPrev.classList.toggle('opacity-50', currentSlide === 0);
    carouselNext.classList.toggle('opacity-50', currentSlide === totalSlides - 1);
  }

  function goToSlide(index) {
    currentSlide = Math.max(0, Math.min(index, totalSlides - 1));
    updateCarousel();
  }

  function nextSlide() {
    if (currentSlide < totalSlides - 1) {
      goToSlide(currentSlide + 1);
    }
  }

  function prevSlide() {
    if (currentSlide > 0) {
      goToSlide(currentSlide - 1);
    }
  }

  carouselPrev.addEventListener('click', prevSlide);
  carouselNext.addEventListener('click', nextSlide);

  function openModal(productKey) {
    const product = PRODUCT_DATA[productKey];
    const links = STRIPE_LINKS[currentCountry] || STRIPE_LINKS['NL'];
    currentStripeLink = links[productKey];

    // Build carousel
    totalSlides = product.images.length;
    currentSlide = 0;
    
    carouselTrack.innerHTML = product.images.map(img => 
      `<div class="w-full flex-shrink-0">
        <img src="${img}" alt="${product.title}" class="w-full max-w-sm mx-auto object-contain aspect-square">
      </div>`
    ).join('');
    
    // Build dots
    carouselDots.innerHTML = product.images.map((_, i) => 
      `<button class="w-2.5 h-2.5 rounded-full transition-colors ${i === 0 ? 'bg-[#2d5a27]' : 'bg-gray-300'}" data-slide="${i}"></button>`
    ).join('');
    
    // Add dot click handlers
    carouselDots.querySelectorAll('button').forEach(dot => {
      dot.addEventListener('click', () => goToSlide(parseInt(dot.dataset.slide)));
    });

    // Show/hide arrows based on number of images
    const showArrows = totalSlides > 1;
    carouselPrev.classList.toggle('hidden', !showArrows);
    carouselNext.classList.toggle('hidden', !showArrows);
    carouselDots.classList.toggle('hidden', !showArrows);

    updateCarousel();

    // Populate modal info (both mobile and desktop)
    modalTitle.textContent = product.title;
    modalPrice.textContent = product.price;
    document.getElementById('modal-title-mobile').textContent = product.title;
    document.getElementById('modal-price-mobile').textContent = product.price;
    
    // Build includes list
    modalIncludes.innerHTML = product.includes.map(item => 
      `<li class="flex items-start gap-2">
        <svg class="w-5 h-5 text-[#2d5a27] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
        <span>${item}</span>
      </li>`
    ).join('');

    // Reset state
    termsCheckbox.checked = false;
    termsError.classList.add('hidden');

    // Show modal
    modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modal.classList.add('hidden');
    document.body.style.overflow = '';
    currentStripeLink = null;
  }

  function handleCheckout() {
    if (!termsCheckbox.checked) {
      termsError.classList.remove('hidden');
      termsCheckbox.focus();
      return;
    }
    
    if (currentStripeLink) {
      window.location.href = currentStripeLink;
    }
  }

  // Event listeners
  modalBackdrop.addEventListener('click', closeModal);
  modalClose.addEventListener('click', closeModal);
  checkoutBtn.addEventListener('click', handleCheckout);
  
  termsCheckbox.addEventListener('change', () => {
    if (termsCheckbox.checked) {
      termsError.classList.add('hidden');
    }
  });

  // Close on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
      closeModal();
    }
  });

  function showShop(countryCode, isSupported) {
    currentCountry = countryCode;
    document.getElementById('shop-loading').classList.add('hidden');
    document.getElementById('shop-products').classList.remove('hidden');

    if (isSupported) {
      document.querySelectorAll('.buy-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          openModal(btn.dataset.product);
        });
      });
    } else {
      document.getElementById('shop-unavailable').classList.remove('hidden');
      document.querySelectorAll('.buy-btn').forEach(btn => {
        btn.removeAttribute('href');
        btn.classList.add('opacity-50', 'cursor-not-allowed', 'pointer-events-none');
        btn.textContent = 'Unavailable';
      });
    }
  }

  fetch('https://ipapi.co/json/')
    .then(res => res.json())
    .then(data => {
      const country = data.country_code;
      const countryName = data.country_name;
      const isSupported = SUPPORTED_COUNTRIES.includes(country);
      if (!isSupported && countryName) {
        document.getElementById('user-country').textContent = countryName;
        document.getElementById('mc-country').value = countryName;
      }
      showShop(country, isSupported);
    })
    .catch(() => {
      showShop('NL', true);
    });
})();
</script>
