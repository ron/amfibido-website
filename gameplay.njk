<style>
/* Phase Animation Styles */
.phase-slide {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.6s ease-in-out, visibility 0.6s;
}

.phase-slide.phase-active {
  position: relative;
  opacity: 1;
  visibility: visible;
}

.phase-slide .phase-image {
  opacity: 0;
  transform: scale(0.95);
  transition: opacity 0.8s ease-out, transform 0.8s ease-out;
}

.phase-slide.phase-active .phase-image {
  opacity: 1;
  transform: scale(1);
}

.phase-slide .phase-step-badge,
.phase-slide .phase-title,
.phase-slide .phase-list-item {
  opacity: 0;
  transform: translateY(20px);
}

.phase-slide.phase-active .phase-step-badge {
  animation: slideInText 0.6s ease-out 0.5s forwards;
}

.phase-slide.phase-active .phase-title {
  animation: slideInText 0.6s ease-out 0.5s forwards;
}

.phase-slide.phase-active .phase-list-item:nth-child(1) {
  animation: slideInText 0.6s ease-out 1.5s forwards;
}

.phase-slide.phase-active .phase-list-item:nth-child(2) {
  animation: slideInText 0.6s ease-out 2.5s forwards;
}

.phase-slide.phase-active .phase-list-item:nth-child(3) {
  animation: slideInText 0.6s ease-out 3.5s forwards;
}

.phase-slide.phase-active .phase-list-item:nth-child(4) {
  animation: slideInText 0.6s ease-out 4.5s forwards;
}

.phase-slide.phase-active .phase-list-item:nth-child(5) {
  animation: slideInText 0.6s ease-out 5.5s forwards;
}

@keyframes slideInText {
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Phase Indicators */
.phase-indicator {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
  padding: 0.5rem 1rem;
  background: transparent;
  border: none;
  cursor: pointer;
  transition: all 0.3s ease;
}

.indicator-dot {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  transition: all 0.3s ease;
}

.phase-indicator-active .indicator-dot,
.phase-indicator:hover .indicator-dot {
  background: #ff6b1f;
  box-shadow: 0 0 12px rgba(255, 107, 31, 0.6);
}

.indicator-label {
  font-size: 0.875rem;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.5);
  transition: color 0.3s ease;
}

.phase-indicator-active .indicator-label,
.phase-indicator:hover .indicator-label {
  color: white;
}

/* Progress Bar Animation */
.phase-progress-bar {
  transition: width 0.1s linear;
}

@keyframes progressFill {
  from { width: 0%; }
  to { width: 100%; }
}

.phase-progress-bar.animating {
  animation: progressFill 10s linear forwards;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const PHASE_DURATION = 10000;
  const phases = document.querySelectorAll('.phase-slide');
  const indicators = document.querySelectorAll('.phase-indicator');
  const progressBar = document.querySelector('.phase-progress-bar');
  let currentPhase = 0;
  let intervalId = null;
  let isPaused = false;

  if (!phases.length || !progressBar) return;

  function showPhase(index) {
    phases.forEach((phase, i) => {
      phase.classList.toggle('phase-active', i === index);
    });
    indicators.forEach((indicator, i) => {
      indicator.classList.toggle('phase-indicator-active', i === index);
    });
    progressBar.classList.remove('animating');
    void progressBar.offsetWidth;
    progressBar.classList.add('animating');
    currentPhase = index;
  }

  function nextPhase() {
    const next = (currentPhase + 1) % phases.length;
    showPhase(next);
  }

  function startAutoPlay() {
    if (intervalId) clearInterval(intervalId);
    intervalId = setInterval(function() {
      if (!isPaused) nextPhase();
    }, PHASE_DURATION);
  }

  indicators.forEach(function(indicator) {
    indicator.addEventListener('click', function() {
      const target = parseInt(indicator.dataset.target);
      showPhase(target);
      startAutoPlay();
    });
  });

  const container = document.querySelector('.phases-container');
  if (container) {
    container.addEventListener('mouseenter', function() { isPaused = true; });
    container.addEventListener('mouseleave', function() { isPaused = false; });
  }

  showPhase(0);
  startAutoPlay();
});
</script>

