---
layout: base.njk
title: "Rules | Amfibido"
description: "Download the official Amfibido game manual and learn how to play."
---

<section class="py-10 md:py-20 bg-white">
  <div class="container mx-auto px-4 md:px-6">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-headings font-bold text-[#2d5a27] mb-8 text-center">Rules</h1>

      <p class="text-lg text-gray-700 leading-relaxed text-center mb-12 max-w-2xl mx-auto">
        Learn how to play Amfibido with our comprehensive game manual or watch the rules explanation video below.
      </p>

      <div class="text-center mb-12">
        <a href="{{ '/documents/Amfibido Game Manual.pdf' | url }}" target="_blank" rel="noopener noreferrer"
           class="inline-flex items-center gap-3 bg-[#2d5a27] text-white px-8 py-4 rounded-lg font-headings font-semibold text-xl hover:bg-[#234520] transition-all duration-300 transform hover:scale-105 shadow-lg">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
          Download Game Manual (PDF)
        </a>
      </div>

      <!-- Rules Video -->
      <div>
        <div class="aspect-video bg-gray-100 rounded-2xl border-2 border-gray-200 flex items-center justify-center">
          <div class="text-center text-gray-500">
            <svg class="w-16 h-16 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <p class="text-lg font-medium">Rules video coming soon</p>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- Chat Button -->
<button id="chat-toggle"
        class="fixed bottom-4 right-4 sm:bottom-6 sm:right-6 z-50 w-14 h-14 bg-[#2d5a27] hover:bg-[#234520] text-white rounded-full shadow-lg flex items-center justify-center transition-all duration-300 hover:scale-110"
        aria-label="Open chat">
  <svg id="chat-icon-open" class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
  </svg>
  <svg id="chat-icon-close" class="w-7 h-7 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
  </svg>
</button>

<!-- Chat Window -->
<div id="chat-window" class="hidden fixed z-50 inset-x-0 bottom-0 sm:inset-auto sm:bottom-24 sm:right-6 w-full sm:w-96 h-[50vh] sm:h-[500px] bg-white sm:rounded-2xl shadow-2xl border border-gray-200 overflow-hidden flex flex-col">
    <!-- Header -->
    <div class="bg-[#2d5a27] text-white px-4 py-3 flex items-center justify-between shrink-0">
      <div>
        <h3 class="font-headings font-semibold">Ask about the rules</h3>
        <p class="text-sm text-green-100">Powered by AI</p>
      </div>
      <button id="chat-close-mobile" class="sm:hidden p-2 hover:bg-[#234520] rounded-lg transition-colors" aria-label="Close chat">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <!-- Messages -->
    <div id="chat-messages" class="flex-1 sm:h-80 overflow-y-auto p-4 space-y-3 bg-gray-50">
      <div class="flex justify-start">
        <div class="bg-white rounded-lg px-4 py-2 shadow-sm max-w-[85%] border border-gray-100">
          <p class="text-gray-700 text-sm">I'm Mr Minami, I know everything about the Amfibido rules. Ask away!</p>
        </div>
      </div>
    </div>

    <!-- Input -->
    <div class="p-3 border-t border-gray-200 bg-white shrink-0 safe-area-bottom">
      <form id="chat-form" class="flex gap-2">
        <input type="text"
               id="chat-input"
               placeholder="Ask a question..."
               class="flex-1 px-4 py-3 sm:py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#2d5a27] focus:border-transparent text-base sm:text-sm"
               autocomplete="off">
        <button type="submit"
                id="chat-submit"
                class="px-4 py-3 sm:py-2 bg-[#2d5a27] text-white rounded-lg hover:bg-[#234520] transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
          </svg>
        </button>
      </form>
    </div>
  </div>

<style>
  .safe-area-bottom {
    padding-bottom: max(0.75rem, env(safe-area-inset-bottom));
  }
</style>

<script>
(function() {
  const WORKER_URL = 'https://chat.amfibido.workers.dev';

  const chatToggle = document.getElementById('chat-toggle');
  const chatWindow = document.getElementById('chat-window');
  const chatForm = document.getElementById('chat-form');
  const chatInput = document.getElementById('chat-input');
  const chatMessages = document.getElementById('chat-messages');
  const chatSubmit = document.getElementById('chat-submit');
  const iconOpen = document.getElementById('chat-icon-open');
  const iconClose = document.getElementById('chat-icon-close');

  let isOpen = false;
  let history = [];

  const chatCloseMobile = document.getElementById('chat-close-mobile');

  function toggleChat(open) {
    isOpen = open;
    chatWindow.classList.toggle('hidden', !isOpen);
    iconOpen.classList.toggle('hidden', isOpen);
    iconClose.classList.toggle('hidden', !isOpen);
    if (isOpen) {
      chatInput.focus();
    }
  }

  chatToggle.addEventListener('click', () => toggleChat(!isOpen));
  chatCloseMobile.addEventListener('click', () => toggleChat(false));

  function parseMarkdown(text) {
    return text
      .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
      .replace(/\*(.+?)\*/g, '<em>$1</em>')
      .replace(/`(.+?)`/g, '<code class="bg-gray-100 px-1 rounded text-sm">$1</code>')
      .replace(/^\d+\.\s+(.+)$/gm, '<li>$1</li>')
      .replace(/(<li>.*<\/li>)/s, '<ol class="list-decimal list-inside space-y-1 my-2">$1</ol>')
      .replace(/^[-•]\s+(.+)$/gm, '<li>$1</li>')
      .replace(/\n/g, '<br>');
  }

  function addMessage(content, isUser) {
    const wrapper = document.createElement('div');
    wrapper.className = `flex ${isUser ? 'justify-end' : 'justify-start'}`;

    const bubble = document.createElement('div');
    bubble.className = isUser
      ? 'bg-[#2d5a27] text-white rounded-lg px-4 py-2 max-w-[85%]'
      : 'bg-white rounded-lg px-4 py-2 shadow-sm max-w-[85%] border border-gray-100';

    const text = document.createElement('div');
    text.className = `text-sm ${isUser ? '' : 'text-gray-700'}`;

    if (isUser) {
      text.textContent = content;
    } else {
      text.innerHTML = parseMarkdown(content);
    }

    bubble.appendChild(text);
    wrapper.appendChild(bubble);
    chatMessages.appendChild(wrapper);
    chatMessages.scrollTop = chatMessages.scrollHeight;
  }

  function addTypingIndicator() {
    const wrapper = document.createElement('div');
    wrapper.id = 'typing-indicator';
    wrapper.className = 'flex justify-start';
    wrapper.innerHTML = `
      <div class="bg-white rounded-lg px-4 py-3 shadow-sm border border-gray-100">
        <div class="flex space-x-1">
          <div class="w-2 h-2 bg-gray-400 rounded-full animate-bounce" style="animation-delay: 0ms"></div>
          <div class="w-2 h-2 bg-gray-400 rounded-full animate-bounce" style="animation-delay: 150ms"></div>
          <div class="w-2 h-2 bg-gray-400 rounded-full animate-bounce" style="animation-delay: 300ms"></div>
        </div>
      </div>
    `;
    chatMessages.appendChild(wrapper);
    chatMessages.scrollTop = chatMessages.scrollHeight;
  }

  function removeTypingIndicator() {
    const indicator = document.getElementById('typing-indicator');
    if (indicator) indicator.remove();
  }

  chatForm.addEventListener('submit', async (e) => {
    e.preventDefault();

    const message = chatInput.value.trim();
    if (!message) return;

    chatInput.value = '';
    chatSubmit.disabled = true;
    chatInput.disabled = true;

    addMessage(message, true);
    addTypingIndicator();

    try {
      const response = await fetch(WORKER_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message, history }),
      });

      const data = await response.json();
      removeTypingIndicator();

      if (data.error) {
        addMessage('Sorry, something went wrong. Please try again.', false);
      } else {
        addMessage(data.reply, false);
        history.push({ role: 'user', content: message });
        history.push({ role: 'assistant', content: data.reply });
        if (history.length > 20) history = history.slice(-20);
      }
    } catch (error) {
      removeTypingIndicator();
      addMessage('Sorry, I couldn\'t connect. Please try again later.', false);
    }

    chatSubmit.disabled = false;
    chatInput.disabled = false;
    chatInput.focus();
  });
})();
</script>
